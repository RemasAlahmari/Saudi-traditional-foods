# =============================================
# APACHE CONFIGURATION — Saudi Foods Backend
# =============================================
# Place this file in the backend/ root directory.
# Requires mod_rewrite to be enabled in XAMPP.

Options -Indexes                    # Disable directory listing
Options -MultiViews

RewriteEngine On

# ── CORS Preflight ────────────────────────────
# Apache-level CORS for OPTIONS preflight requests
# (also handled in PHP, but belt-and-braces)
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=204,L]

# ── Security Headers ──────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-Frame-Options           "DENY"
    Header always set X-XSS-Protection          "1; mode=block"
    Header always set Referrer-Policy           "strict-origin-when-cross-origin"
    # Remove the PHP version header
    Header unset X-Powered-By
</IfModule>

# ── Deny access to sensitive files ───────────
<FilesMatch "\.(env|log|sql|md|sh|git)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to config and middleware folders
RewriteRule ^config/.*$     - [F,L]
RewriteRule ^middleware/.*$ - [F,L]
RewriteRule ^utils/.*$      - [F,L]

# ── Force JSON Content-Type for /api/ ────────
<FilesMatch "\.php$">
    <IfModule mod_headers.c>
        Header set X-API-Version "1.0"
    </IfModule>
</FilesMatch>

# ── PHP Settings ──────────────────────────────
<IfModule mod_php.c>
    php_flag  display_errors      Off      # Never show errors to users
    php_flag  log_errors          On
    php_value error_log           ../logs/php_errors.log
    php_value upload_max_filesize 2M
    php_value post_max_size       8M
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode  1
</IfModule>
